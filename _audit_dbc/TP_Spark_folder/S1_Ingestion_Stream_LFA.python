itération :\n1. Lance le simulateur en **thread daemon** (1 batch = 20 trajets).\n2. `t.join()` attend l'écriture du fichier Parquet.\n3. Job streaming `availableNow=True` consomme les nouveaux fichiers.\n4. `awaitTermination()` jusqu'à la fin du job.\n5. Pause 20 s avant l'itération suivante (sauf dernière).","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"8262bfe3-f915-4b7f-a959-b75ccfb0f132"},{"version":"CommandV1","origId":8663278405180158,"guid":"f6d4a044-5d43-43cc-ad96-51b270937cdc","subtype":"command","commandType":"auto","position":14.0,"command":"import time\nimport threading\n\nNB_ITERATIONS = 10\nPAUSE_SECONDS = 20\n\nbatches_metrics = []\n\nfor i in range(NB_ITERATIONS):\n    print(f\"\\n=== Itération {i+1}/{NB_ITERATIONS} ===\")\n\n    # 1. Simulateur en thread daemon (1 batch)\n    sim = TaxiStreamSimulator(\n        output_path=SIM_OUTPUT_PATH,\n        rate=20,\n        interval_seconds=0,\n        mode=\"normal\",\n        duration_batches=1,\n        seed=i,\n        verbose=False,\n    )\n    t = threading.Thread(target=sim.run, daemon=True)\n    t.start()\n    t.join()\n    print(f\"  Simulateur OK (seed={i})\")\n\n    # 2. Job streaming availableNow\n    df_stream = build_bronze_stream()\n    query = (\n        df_stream.writeStream\n            .format(\"delta\")\n            .outputMode(\"append\")\n            .option(\"checkpointLocation\", CHECKPOINT_PATH)\n            .trigger(availableNow=True)\n            .toTable(BRONZE_STREAM_TABLE)\n    )\n    query.awaitTermination()\n\n    # 3. Métriques\n    last = query.lastProgress\n    if last:\n        batches_metrics.append({\n            \"iteration\": i + 1,\n            \"numInputRows\": last.get(\"numInputRows\", 0),\n            \"batchDuration_ms\": last.get(\"batchDuration\", 0),\n            \"inputRowsPerSec\": last.get(\"inputRowsPerSecond\", 0),\n        })\n        print(f\"  → numInputRows={last.get('numInputRows')} \"\n              f\"batchDuration={last.get('batchDuration')} ms\")\n\n    if i < NB_ITERATIONS - 1:\n        time.sleep(PAUSE_SECONDS)\n\nprint(\"\\nPipeline terminé.\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"\n=== Itération 1/10 ===\n  Simulateur OK (seed=0)\n  → numInputRows=20 batchDuration=6209 ms\n\n=== Itération 2/10 ===\n  Simulateur OK (seed=1)\n  → numInputRows=20 batchDuration=5678 ms\n\n=== Itération 3/10 ===\n  Simulateur OK (seed=2)\n  → numInputRows=20 batchDuration=5932 ms\n\n=== Itération 4/10 ===\n  Simulateur OK (seed=3)\n  → numInputRows=20 batchDuration=5875 ms\n\n=== Itération 5/10 ===\n  Simulateur OK (seed=4)\n  → numInputRows=20 batchDuration=5800 ms\n\n=== Itération 6/10 ===\n  Simulateur OK (seed=5)\n  → numInputRows=20 batchDuration=5818 ms\n\n=== Itération 7/10 ===\n  Simulateur OK (seed=6)\n  → numInputRows=20 batchDuration=5416 ms\n\n=== Itération 8/10 ===\n  Simulateur OK (seed=7)\n  → numInputRows=20 batchDuration=5758 ms\n\n=== Itération 9/10 ===\n  Simulateur OK (seed=8)\n  → numInputRows=20 batchDuration=6053 ms\n\n=== Itération 10/10 ===\n  Simulateur OK (seed=9)\n  → numInputRows=20 batchDuration=5774 ms\n\nPipeline terminé.\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_stream","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"VendorID","nullable":true,"type":"integer"},{"metadata":{},"name":"tpep_pickup_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"tpep_dropoff_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"passenger_count","nullable":true,"type":"double"},{"metadata":{},"name":"trip_distance","nullable":true,"type":"double"},{"metadata":{},"name":"PULocationID","nullable":true,"type":"integer"},{"metadata":{},"name":"DOLocationID","nullable":true,"type":"integer"},{"metadata":{},"name":"payment_type","nullable":true,"type":"integer"},{"metadata":{},"name":"fare_amount","nullable":true,"type":"double"},{"metadata":{},"name":"tip_amount","nullable":true,"type":"double"},{"metadata":{},"name":"total_amount","nullable":true,"type":"double"},{"metadata":{},"name":"sim_is_corrupted","nullable":true,"type":"boolean"},{"metadata":{},"name":"sim_batch_id","nullable":true,"type":"integer"},{"metadata":{},"name":"_rescued_data","nullable":true,"type":"string"},{"metadata":{},"name":"ingestion_timestamp","nullable":false,"type":"timestamp"},{"metadata":{},"name":"source_file","nullable":false,"type":"string"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":null,"sqlProps":null},"workflows":[],"startTime":1779179904364,"submitTime":1779179900330,"finishTime":1779180174890,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",930]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"3af8a630-51f8-47aa-a8ef-f71994d18e3e"},{"version":"CommandV1","origId":8663278405180159,"guid":"65084c7b-d383-48b6-a054-9c8799be3265","subtype":"command","commandType":"auto","position":15.0,"command":"%md\n## 6. Preuve d'exécution — métriques par itération\n\n`query.lastProgress` consigne les métriques de chaque appel\n`availableNow` : `numInputRows`, `batchDuration`, `inputRowsPerSecond`.\nPour la trace Spark UI officielle, ouvrir **View → Spark UI → Structured\nStreaming** dans la barre du notebook après exécution (l'historique des\nqueries contient une entrée par itération).","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsis