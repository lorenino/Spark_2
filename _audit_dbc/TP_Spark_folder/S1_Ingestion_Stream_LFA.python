38;5;124m\"\u001B[39m)\n","\u001B[0;31mAssertionError\u001B[0m: ❌ Fichier absent : /Volumes/workspace/tp_spark_lfa/scripts/taxi_simulator.py\n   → uploader taxi_simulator.py dans le volume scripts via Catalog UI."],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":{"ename":"AssertionError","evalue":"❌ Fichier absent : /Volumes/workspace/tp_spark_lfa/scripts/taxi_simulator.py\n   → uploader taxi_simulator.py dans le volume scripts via Catalog UI."},"sqlProps":null},"workflows":[],"startTime":1779179903355,"submitTime":1779179900289,"finishTime":1779179903647,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",81]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"d1d8411e-9072-436d-9dbb-d1d1abf9b38b"},{"version":"CommandV1","origId":8663278405180153,"guid":"4683c377-9342-4403-abc7-904c76b92697","subtype":"command","commandType":"auto","position":9.0,"command":"%md\n## 3. Configuration du simulateur — justification\n\nLe simulateur est lancé dans un **thread daemon** (s'arrête tout seul si\nle notebook se détache du cluster).\n\n| Paramètre | Valeur | Raison |\n|---|---|---|\n| `rate` | **20 trajets/batch** | Borne basse de la fourchette recommandée (10-50). Volume suffisant pour observer la distribution NYC Taxi sans saturer le single-node serverless. |\n| `interval_seconds` | **0** | On gère la cadence dans la boucle Python externe (20 s entre itérations). Le sleep interne du simulateur interférerait avec `t.join()`. |\n| `duration_batches` | **1** | Un seul batch par itération → contrôle granulaire de l'alternance sim/job. 10 itérations = 10 micro-batches Spark (≥ 5 exigés). |\n| `mode` | **`normal`** | Imposé par le sujet (pas de chaos, pas de late). |\n| `seed` | **`i`** | Seed variable par itération → variété sans perdre la reproductibilité. |\n| `late_data_ratio` | **`0.0`** | Pas de retard event-time en mode normal. |\n\n**Total simulé** : 10 × 20 = **200 lignes**, ~3 min réel.","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"f6bdf50a-359d-42ac-ae1c-38f55af2426c"},{"version":"CommandV1","origId":8663278405180154,"guid":"358695f3-86da-4561-8ab6-8c83797dd698","subtype":"command","commandType":"auto","position":10.0,"command":"import sys\nif VOL_SCRIPTS not in sys.path:\n    sys.path.insert(0, VOL_SCRIPTS)\n\nfrom taxi_simulator import TaxiStreamSimulator\nprint(\"✓ TaxiStreamSimulator importé.\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"✓ TaxiStreamSimulator importé.\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":null,"sqlProps":null},"workflows":[],"startTime":1779179903655,"submitTime":1779179900302,"finishTime":1779179903747,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",31]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"3071b819-07f5-474d-be78-4c6213abdbc7"},{"version":"CommandV1","origId":8663278405180155,"guid":"8dd02a8c-42b5-48c3-96aa-9b43ca6a1962","subtype":"command","commandType":"auto","position":11.0,"command":"%md\n## 4. Pipeline Bronze streaming — Auto Loader + Delta\n\n### Trigger : `availableNow=True`\n\nLe compute serverless du compte Free Edition **interdit**\n`processingTime`. `availableNow=True` traite ce qui est disponible puis\ns'arrête : on l'invoque 10 fois dans la boucle pour simuler le continu.\n\n### Checkpoint : Volume Unity Catalog persistant\n\nLe checkpoint est dans un **Volume UC** (`/Volumes/.../checkpoints/`),\npas en DBFS ni `/tmp/`. Raisons :\n- Survie aux redémarrages cluster (timeout 2 h compte Free).\n- Idempotence : Auto Loader retient les fichiers déjà traités →\n  exactly-once.\n- Lié à *cette* query : changement de schéma → suppression manuelle.\n\n### Colonnes techniques\n\n- `ingestion_timestamp` = `current_timestamp()` au micro-batch\n- `source_file` = `_metadata.file_path`","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"c3c36d0a-c52e-46dd-bd8d-e2575c9eafff"},{"version":"CommandV1","origId":8663278405180156,"guid":"9dd308f0-ad98-4d99-bfa0-2745b220da5c","subtype":"command","commandType":"auto","position":12.0,"command":"from pyspark.sql.functions import current_timestamp, col\n\ndef build_bronze_stream():\n    \"\"\"DataFrame streaming Bronze depuis Auto Loader.\"\"\"\n    return (\n        spark.readStream\n            .format(\"cloudFiles\")\n            .option(\"cloudFiles.format\", \"parquet\")\n            .option(\"cloudFiles.schemaLocation\", SCHEMA_LOCATION)\n            .option(\"cloudFiles.inferColumnTypes\", \"true\")\n            .load(SIM_OUTPUT_PATH)\n            .withColumn(\"ingestion_timestamp\", current_timestamp())\n            .withColumn(\"source_file\", col(\"_metadata.file_path\"))\n    )\n\n# Sanity check : schéma sans démarrer le job (lance un mini-scan Auto Loader)\ndf_stream = build_bronze_stream()\ndf_stream.printSchema()","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"root\n |-- VendorID: integer (nullable = true)\n |-- tpep_pickup_datetime: timestamp_ntz (nullable = true)\n |-- tpep_dropoff_datetime: timestamp_ntz (nullable = true)\n |-- passenger_count: double (nullable = true)\n |-- trip_distance: double (nullable = true)\n |-- PULocationID: integer (nullable = true)\n |-- DOLocationID: integer (nullable = true)\n |-- payment_type: integer (nullable = true)\n |-- fare_amount: double (nullable = true)\n |-- tip_amount: double (nullable = true)\n |-- total_amount: double (nullable = true)\n |-- sim_is_corrupted: boolean (nullable = true)\n |-- sim_batch_id: integer (nullable = true)\n |-- _rescued_data: string (nullable = true)\n |-- ingestion_timestamp: timestamp (nullable = false)\n |-- source_file: string (nullable = false)\n\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_stream","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"VendorID","nullable":true,"type":"integer"},{"metadata":{},"name":"tpep_pickup_datetime","nullable":true,"type":"ti