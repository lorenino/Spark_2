       |NULL         |2026-05-19 08:27:05.035|/Volumes/workspace/tp_spark_lfa/raw_data/stream_input/batch_20260519_082700_0000.parquet|\n|1       |2026-05-19 07:31:29 |2026-05-19 07:32:29       |1.0            |0.1          |40          |261         |1           |6.47       |1.57      |8.84        |false           |0           |NULL         |2026-05-19 08:27:05.035|/Volumes/workspace/tp_spark_lfa/raw_data/stream_input/batch_20260519_082700_0000.parquet|\n|2       |2026-05-19 09:13:59 |2026-05-19 09:37:16.341459|1.0            |6.56         |7           |142         |1           |7.32       |1.2       |9.32        |false           |0           |NULL         |2026-05-19 08:27:05.035|/Volumes/workspace/tp_spark_lfa/raw_data/stream_input/batch_20260519_082700_0000.parquet|\n|1       |2026-05-19 08:48:57 |2026-05-19 08:58:01.417654|1.0            |2.37         |237         |138         |2           |33.02      |4.61      |38.43       |false           |0           |NULL         |2026-05-19 08:27:05.035|/Volumes/workspace/tp_spark_lfa/raw_data/stream_input/batch_20260519_082700_0000.parquet|\n+--------+--------------------+--------------------------+---------------+-------------+------------+------------+------------+-----------+----------+------------+----------------+------------+-------------+-----------------------+----------------------------------------------------------------------------------------+\nonly showing top 5 rows\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":null,"sqlProps":null},"workflows":[],"startTime":1779180175923,"submitTime":1779179900346,"finishTime":1779180177595,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",2975]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"0e6d2ef5-d1e7-473d-bad3-e4b5f988d792"},{"version":"CommandV1","origId":8663278405180162,"guid":"ed8360ad-9aa6-4672-ab26-8160e85ea31a","subtype":"command","commandType":"auto","position":18.0,"command":"%md\n## 7. Validation cohérence schéma vs Spark Core\n\nRéférence : `bronze_taxi_trips` de Spark Core S5 si présente. Sinon\n(workspace from scratch), on compare au **schéma NYC Taxi canonique**\ndocumenté par le simulateur (PDF cours).\n\nDifférences attendues côté stream (acceptables) :\n- `ingestion_timestamp` — ajouté par le pipeline (technique)\n- `source_file` — ajouté par le pipeline (technique)\n- `sim_batch_id` — injecté par le simulateur\n- `sim_is_corrupted` — injecté par le simulateur (oracle quarantaine S3)","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"f774a27e-41a1-4f5a-8b73-86257415e0b5"},{"version":"CommandV1","origId":8663278405180163,"guid":"f8258722-cd55-4871-a470-a3ea57ad694a","subtype":"command","commandType":"auto","position":19.0,"command":"# Schéma NYC Taxi canonique (du PDF Simulateur)\nNYC_TAXI_CANONICAL = {\n    \"VendorID\":              \"int\",\n    \"tpep_pickup_datetime\":  \"timestamp\",\n    \"tpep_dropoff_datetime\": \"timestamp\",\n    \"passenger_count\":       \"double\",\n    \"trip_distance\":         \"double\",\n    \"PULocationID\":          \"int\",\n    \"DOLocationID\":          \"int\",\n    \"payment_type\":          \"int\",\n    \"fare_amount\":           \"double\",\n    \"tip_amount\":            \"double\",\n    \"total_amount\":          \"double\",\n}\n\ndef schema_signature(table_name):\n    return {f.name: f.dataType.simpleString() for f in spark.table(table_name).schema.fields}\n\nsig_stream = schema_signature(BRONZE_STREAM_TABLE)\n\n# Tentative de récupérer le schéma batch (Spark Core S5)\ntry:\n    sig_batch = schema_signature(BRONZE_BATCH_TABLE)\n    reference_name = \"bronze_taxi_trips (Spark Core S5)\"\nexcept Exception:\n    print(f\"⚠️  Table batch {BRONZE_BATCH_TABLE} absente — fallback sur le \"\n          f\"schéma NYC Taxi canonique documenté.\")\n    sig_batch = NYC_TAXI_CANONICAL\n    reference_name = \"NYC Taxi canonique (doc simulateur)\"\n\ncommon      = set(sig_stream) & set(sig_batch)\nonly_stream = set(sig_stream) - set(sig_batch)\nonly_batch  = set(sig_batch)  - set(sig_stream)\n\nprint(f\"\\n=== Comparaison vs {reference_name} ===\\n\")\nprint(f\"Colonnes communes ({len(common)}) :\")\nfor c in sorted(common):\n    same = \"✓\" if sig_stream[c] == sig_batch[c] else \"✗\"\n    print(f\"  {same} {c:25s}  stream={sig_stream[c]:15s} | ref={sig_batch[c]}\")\n\nprint(f\"\\nUniquement dans bronze_stream_taxi ({len(only_stream)}) :\")\nfor c in sorted(only_stream):\n    print(f\"  + {c}: {sig_stream[c]}\")\n\nprint(f\"\\nUniquement dans la référence ({len(only_batch)}) :\")\nfor c in sorted(only_batch):\n    print(f\"  - {c}: {sig_batch[c]}\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"⚠️  Table batch workspace.tp_spark_lfa.bronze_taxi_trips absente — fallback sur le schéma NYC Taxi canonique documenté.\n\n=== Comparaison vs NYC Taxi canonique (doc simulateur) ===\n\nColonnes communes (11) :\n  ✓ DOLocationID               stream=int             | ref=int\n  ✓ PULocationID               stream=int             | ref=int\n  ✓ VendorID                   stream=int             | ref=int\n  ✓ fare_amount                stream=double          | ref=double\n  ✓ passenger_count            stream=double          | ref=double\n  ✓ payment_type               stream=int             | ref=int\n  ✓ tip_amount                 stream=double          | ref=double\n  ✓ total_amount               stream=double          | ref=double\n  ✗ tpep_dropoff_datetime      stream=timestamp_ntz   | ref=timestamp\n  ✗ tpep_pickup_datetime       stream=timestamp_ntz   | ref=timestamp\n  ✓ trip_distance              stream=double          | ref=double\n\nUniquement dans bronze_stream_taxi (5) :\n  + _rescued_data: string\n  + ingestion_timestamp: timestamp\n  + sim_batch_id: int\n  + sim_is_corrupted: boolean\n  + source_file: string\n\nUniquement dans la référence (0) :\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":null,"sqlProps":null},"workflows":[],"startTime":1779180177605,"submitTime":1779179900360,"finishTime":1779180178494,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",1152]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"e33069b6-f3c8-4839-bdaa-86689b96a8cd"},{"version":"CommandV1","origId":8663278405180164,"guid":"33342bef-47f2-4f76-b9d2-110b76d61b8d","subtype":"command","commandType":"auto","position":20.0,"command":"%md\n### Commentaire\n\nLes divergences côté stream sont **attendues** :\n- `ingestion_timestamp` + `source_file` : colonnes techniques ajoutées\n  explicitement par le pipeline Bronze pour la traçabilité.\n- `sim_batch_id` + `sim_is_corrupted` : ajoutées par le simulateur.\n  `sim_is_corrupted` est un **oracle** (à n'utiliser qu'a posteriori en S3\n  pour mesurer le recall de la quarantaine, jamais comme feature).\n\nSur la comparaison ci-dessus, le mismatch éventuel sur les types\n`int vs integer` est une équivalence cosmétique (`int = integer = int32`\ndans Spark) — pas une vraie divergence. Si une **colonne canonique\nmanque** côté stream, c'est que le simulateur ne la génère pas ; à\ncorriger côté simulateur.","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"6fcb3bba-b793-4c56-9a44-4302b288bf6d"},{"version":"CommandV1","origId":8663278405180165,"guid":"418d9635-01cd-4125-8599-320ad1c5469c","subtype":"command","commandType":"auto","position":21.0,"command":"%md\n## 8. Question théorique — Pourquoi `complete` est impraticable pour Bronze\n\nLe mode `complete` impose à Spark de **réécrire intégralement la table\nrésultat à chaque micro-batch**. Sur une table Bronze qui ne fait\nqu'accumuler des évènements, c'est catastrophique :\n\n1. **Coût d'écriture quadratique.** Pour N batches de `rate` lignes,\n   le volume cumulé écrit n'est plus N×rate (append) mais\n   Σᵢ(i×rate) ≈ N²×rate/2. Sur mes 10 batches × 20 lignes c'est\n   anecdotique (~1 100 lignes réécrites pour 200 ingérées), mais à\n   1 000 batches × 1 000 lignes/batch on passe de **10⁶ lignes ingérées\n   à ~5×10⁸ lignes écrites** — 500× plus d'I/O qu'`append`.\n2. **Incompatible avec l'API.** `complete` requiert une **agrégation\n   stateful** dans la query (`groupBy`, `count`...). Une ingestion\n   `readStream → writeStream` sans agrégation lève une\n   `AnalysisException` — Spark refuse car il faudrait conserver tout\n   l'historique en mémoire.\n3. **Pression mémoire driver.** `complete` reconstruit toute la sortie\n   en mémoire avant écriture. Sur compute single-node serverless avec\n   15-30 Go RAM, la table déborde dès quelques centaines de Mo.\n4. **Time-travel Delta dégradé.** En `append`, le journal Delta est\n   incrémental (1 commit = N lignes ajoutées). En `complete`, chaque\n   commit réécrit la table : les versions deviennent des snapshots\n   redondants, `VACUUM` ne libère rien tant qu'on n'expire pas les\n   versions, et le time-travel perd son intérêt analytique.\n5. **Anti-pattern Medallion.** Bronze = source de vérité brute,\n   *append-only par définition*. Réécrire le Bronze à chaque micro-batch\n   contredit la garantie d'immutabilité qui justifie son existence.\n\nEn résumé : `complete` est conçu pour des **résultats agrégés bornés**\n(top-N, leaderboards, dashboards live), pas pour des **flux\nd'évènements append-only**. Pour Bronze, c'est toujours `append`.","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"3bdb3993-3e7d-4dc6-8930-ac8adfd1e715"},{"version":"CommandV1","origId":8663278405180166,"guid":"5117ebb6-50ce-47df-a77c-cbec083734d1","subtype":"command","commandType":"auto","position":22.0,"command":"%md\n## 9. Arrêt explicite des streams (règle transversale du cours)","commandVersion":1,"state":"finished","results":null,"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":null,"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"1b56c5ce-2d67-4be2-939d-f3967bf84d6c"},{"version":"CommandV1","origId":8663278405180167,"guid":"5ddb11de-6a42-4b6e-97a2-9d427d1e893c","subtype":"command","commandType":"auto","position":23.0,"command":"for q in spark.streams.active:\n    print(f\"Stopping query: {q.name} (id={q.id})\")\n    q.stop()\nprint(\"Toutes les streams sont arrêtées.\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Toutes les streams sont arrêtées.\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{},"jupyterProps":null,"sqlProps":null},"workflows":[],"startTime":1779180178505,"submitTime":1779179900405,"finishTime":1779180178796,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",34]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"1fdb3751-17b8-4386-934d-05a55332f286"}],"dashboards":[],"guid":"9dc45cec-0bc1-49f5-8aa4-85039ec66cb6","globalVars":{},"iPythonMetadata":null,"inputWidgets":{},"notebookMetadata":{"pythonIndentUnit":4},"reposExportFormat":"SOURCE","environmentMetadata":null,"computePreferences":null,"inputWidgetPreferences":null,"environmentSerializationPreferences":null}