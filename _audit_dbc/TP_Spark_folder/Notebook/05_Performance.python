istResultMetadata":[],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"581ddd0a-e969-48bf-984a-c3b84a59e881"},{"version":"CommandV1","origId":6943154431065658,"guid":"c1e4a0d9-9a7b-4b08-939d-e0997583fc62","subtype":"command","commandType":"auto","position":1.0,"command":"from pyspark.sql.functions import rand, when, lit\nimport time\n\n# Générer 10 millions de lignes avec 90% sur le même ID (999)\nnum_rows = 10000000\n\ndf_skew = (\n    spark.range(0, num_rows)\n    .withColumn(\"PULocationID\",\n        when(rand() < 0.9, lit(999)).otherwise((rand() * 100).cast(\"int\"))\n    )\n)\n\n# Sauvegarder en Delta\ndf_skew.write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"skewed_trips\")\n\nprint(f\"Dataset piégé de {num_rows} lignes généré !\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Dataset piégé de 10000000 lignes généré !\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_skew","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"id","nullable":false,"type":"long"},{"metadata":{},"name":"PULocationID","nullable":true,"type":"integer"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1774864481636,"submitTime":1774864481550,"finishTime":1774864501231,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDelete