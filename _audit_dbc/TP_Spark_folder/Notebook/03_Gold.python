{"version":"NotebookV1","origId":1164645013340101,"name":"03_Gold","language":"python","commands":[{"version":"CommandV1","origId":8031061953195049,"guid":"8e1fc4ea-c39c-4a2c-a711-1a537251660d","subtype":"command","commandType":"auto","position":4.0,"command":"# Statistiques du pourboire par Borough\ndf_tips_stats = (\n    df_valid\n    .filter(col(\"PU_Borough\").isNotNull())\n    .groupBy(\"PU_Borough\")\n    .agg(\n        avg(\"tip_amount\").alias(\"avg_tip\"),\n        stddev(\"tip_amount\").alias(\"std_tip\"),\n        count(\"tip_amount\").alias(\"n\")\n    )\n    .withColumn(\"ci_95\", lit(1.96) * col(\"std_tip\") / sqrt(col(\"n\")))\n    .withColumn(\"ci_low\", col(\"avg_tip\") - col(\"ci_95\"))\n    .withColumn(\"ci_high\", col(\"avg_tip\") + col(\"ci_95\"))\n    .orderBy(\"avg_tip\", ascending=False)\n)\n\ndisplay(df_tips_stats)","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"table","data":[["EWR",9.578456565656555,11.650487842927678,2475,0.4589998892557137,9.119456676400842,10.037456454912268],["N/A",9.193805561637857,16.20668286634036,9134,0.33236838100949156,8.861437180628366,9.526173942647349],["Queens",7.489101820443701,7.601756814902706,2062572,0.010374459618774092,7.478727360824927,7.499476280062475],["Unknown",3.923213501646541,4.663718246819489,43728,0.04371279430732668,3.879500707339214,3.9669262959538676],["Manhattan",2.6518532584689036,2.967876106406382,19577825,0.0013146786727598375,2.6505385797961436,2.6531679371416637],["Staten Island",1.1202871794871794,6.556456123589472,1950,0.29101000800938875,0.8292771714777907,1.411297187496568],["Brooklyn",0.5545134330576567,2.4658015466962775,699729,0.005777623736107472,0.5487358093215492,0.5602910567937641],["Bronx",0.1424494035036121,1.5310537063060254,163203,0.00742818014737395,0.13502122335623815,0.14987758365098605]],"arguments":{},"addedWidgets":{},"removedWidgets":[],"schema":[{"name":"PU_Borough","type":"\"string\"","metadata":"{}"},{"name":"avg_tip","t