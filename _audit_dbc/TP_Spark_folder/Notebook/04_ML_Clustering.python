{"version":"NotebookV1","origId":1164645013340103,"name":"04_ML_Clustering","language":"python","commands":[{"version":"CommandV1","origId":6414892781516000,"guid":"736f69ad-5f99-4d5c-a0ce-e895d3ea5a85","subtype":"command","commandType":"auto","position":3.0,"command":"# Union avec allowMissingColumns (les Verts ont des colonnes en plus comme ehail_fee)\ndf_all_taxis = df_yellow.unionByName(df_green_raw, allowMissingColumns=True)\n\nprint(f\"Yellow : {df_yellow.count()}\")\nprint(f\"Green  : {df_green_raw.count()}\")\nprint(f\"Total  : {df_all_taxis.count()}\")\n\n# Vérifier qu'on a bien les deux types\ndisplay(df_all_taxis.groupBy(\"taxi_type\").count())","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Yellow : 22560616\nGreen  : 303407\nTotal  : 22864023\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}},{"type":"table","data":[["yellow",22560616],["green",303407]],"arguments":{},"addedWidgets":{},"removedWidgets":[],"schema":[{"name":"taxi_type","type":"\"string\"","metadata":"{}"},{"name":"count","type":"\"long\"","metadata":"{}"}],"overflow":false,"aggData":[],"aggSchema":[],"aggOverflow":false,"aggSeriesLimitReached":false,"aggError":"","aggType":"","plotOptions":null,"isJsonSchema":true,"dbfsResultPath":null,"datasetInfos":[],"columnCustomDisplayInfos":{},"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_all_taxis","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"VendorID","nullable":true,"type":"long"},{"metadata":{},"name":"tpep_pickup_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"tpep_dropoff_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"passenger_count","nullable":true,"type":"double"},{"metadata":{},"name":"trip_distance","nullable":true,"type":"double"},{"metadata":{},"name":"RatecodeID","nullable":true,"type":"double"},{"metadata":{},"name":"store_and_fwd_flag","nullable":true,"type":"string"},{"metadata":{},"name":"PULocationID","nullable":true,"type":"long"},{"metadata":{},"name":"DOLocationID","nullable":true,"type":"long"},{"metadata":{},"name":"payment_type","nullable":true,"type":"long"},{"metadata":{},"name":"fare_amount","nullable":true,"type":"double"},{"metadata":{},"name":"extra","nullable":true,"type":"double"},{"metadata":{},"name":"mta_tax","nullable":true,"type":"double"},{"metadata":{},"name":"tip_amount","nullable":true,"type":"double"},{"metadata":{},"name":"tolls_amount","nullable":true,"type":"double"},{"metadata":{},"name":"improvement_surcharge","nullable":true,"type":"double"},{"metadata":{},"name":"total_amount","nullable":true,"type":"double"},{"metadata":{},"name":"congestion_surcharge","nullable":true,"type":"double"},{"metadata":{},"name":"Airport_fee","nullable":true,"type":"double"},{"metadata":{},"name":"cbd_congestion_fee","nullable":true,"type":"double"},{"metadata":{},"name":"source_file","nullable":true,"type":"string"},{"metadata":{},"name":"PU_Borough","nullable":true,"type":"string"},{"metadata":{},"name":"PU_Zone","nullable":true,"type":"string"},{"metadata":{},"name":"DO_Borough","nullable":true,"type":"string"},{"metadata":{},"name":"DO_Zone","nullable":true,"type":"string"},{"metadata":{},"name":"taxi_type","nullable":false,"type":"string"},{"metadata":{},"name":"lpep_pickup_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"lpep_dropoff_datetime","nullable":true,"type":"timestamp_ntz"},{"metadata":{},"name":"ehail_fee","nullable":true,"type":"double"},{"metadata":{},"name":"trip_type","nullable":true,"type":"long"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602289077,"submitTime":1773602269173,"finishTime":1773602302149,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",52],["table",2]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"39123fb5-46e4-4a83-a7bb-53811d708f9c"},{"version":"CommandV1","origId":6414892781516002,"guid":"473693e8-23cc-493c-8140-1cfffea7296a","subtype":"command","commandType":"auto","position":5.0,"command":"from pyspark.ml.feature import VectorAssembler, StandardScaler\nfrom pyspark.ml.clustering import KMeans\n\n# Features pour le clustering\nfeatures = [\"avg_distance\", \"avg_fare\", \"avg_tip\", \"trips_count\", \"green_taxi_ratio\"]\n\n# Assembler les features\nassembler = VectorAssembler(inputCols=features, outputCol=\"features_raw\")\ndf_assembled = assembler.transform(df_quartiers.na.drop(subset=features))\n\n# Standardiser (comparer ce qui est comparable)\nscaler = StandardScaler(inputCol=\"features_raw\", outputCol=\"features_scaled\", withStd=True, withMean=True)\nscaler_model = scaler.fit(df_assembled)\ndf_scaled = scaler_model.transform(df_assembled)\n\n# K-Means brut (K=4)\nkmeans_brut = KMeans(k=4, seed=42, featuresCol=\"features_scaled\", predictionCol=\"cluster_brut\")\nmodel_brut = kmeans_brut.fit(df_scaled)\ndf_clustered = model_brut.transform(df_scaled)\n\nprint(\"Centres des clusters (brut) :\")\nfor i, center in enumerate(model_brut.clusterCenters()):\n    print(f\"  Cluster {i}: {[round(c, 2) for c in center]}\")\n\ndisplay(df_clustered.select(\"Zone\", \"Borough\", \"trips_count\", \"green_taxi_ratio\", \"avg_fare\", \"cluster_brut\").orderBy(\"cluster_brut\"))","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Centres des clusters (brut) :\n  Cluster 0: [np.float64(-0.09), np.float64(-0.2), np.float64(-0.22), np.float64(0.01), np.float64(-0.19)]\n  Cluster 1: [np.float64(10.02), np.float64(0.22), np.float64(-0.37), np.float64(-0.45), np.float64(0.66)]\n  Cluster 2: [np.float64(0.16), np.float64(2.76), np.float64(2.77), np.float64(0.02), np.float64(-0.22)]\n  Cluster 3: [np.float64(-0.14), np.float64(-0.31), np.float64(0.05), np.float64(-0.22), np.float64(3.8)]\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}},{"type":"table","data":[["Pelham Parkway","Bronx",2374,2.695871946082561,31.473399326032023,0],["Bronxdale","Bronx",2600,3.192307692307692,33.20818846153848,0],["Oakland Gardens","Queens",1055,1.6113744075829384,34.277563981042654,0],["TriBeCa/Civic Center","Manhattan",314561,0.006358067274709834,27.2191938924404,0],["Lower East Side","Manhattan",270078,0.0025918438377061444,25.909987596175764,0],["Midtown Center","Manhattan",1010125,0.0016829600296992945,25.813381254795974,0],["East Flatbush/Remsen Village","Brooklyn",13919,1.8823191321215607,26.7860866441555,0],["Bay Ridge","Brooklyn",8403,1.725574199690587,33.289462096870174,0],["Highbridge Park","Manhattan",377,7.6923076923076925,34.26506631299735,0],["Battery Park","Manhattan",7568,0.0,33.17121696617338,0],["Claremont/Bathgate","Bronx",3934,2.923233350279614,29.17628368073205,0],["Ocean Parkway South","Brooklyn",1405,1.4234875444839856,26.99230604982205,0],["North Corona","Queens",3957,4.447814000505433,28.020136467020457,0],["SoHo","Manhattan",194833,0.003079560444072616,24.771860259812424