metadata":{},"name":"RatecodeID","nullable":true,"type":"long"},{"metadata":{},"name":"PULocationID","nullable":true,"type":"integer"},{"metadata":{},"name":"DOLocationID","nullable":true,"type":"integer"},{"metadata":{},"name":"passenger_count","nullable":true,"type":"long"},{"metadata":{},"name":"trip_distance","nullable":true,"type":"double"},{"metadata":{},"name":"fare_amount","nullable":true,"type":"double"},{"metadata":{},"name":"extra","nullable":true,"type":"double"},{"metadata":{},"name":"mta_tax","nullable":true,"type":"double"},{"metadata":{},"name":"tip_amount","nullable":true,"type":"double"},{"metadata":{},"name":"tolls_amount","nullable":true,"type":"double"},{"metadata":{},"name":"ehail_fee","nullable":true,"type":"double"},{"metadata":{},"name":"improvement_surcharge","nullable":true,"type":"double"},{"metadata":{},"name":"total_amount","nullable":true,"type":"double"},{"metadata":{},"name":"payment_type","nullable":true,"type":"long"},{"metadata":{},"name":"trip_type","nullable":true,"type":"long"},{"metadata":{},"name":"congestion_surcharge","nullable":true,"type":"double"},{"metadata":{},"name":"cbd_congestion_fee","nullable":true,"type":"double"},{"metadata":{},"name":"source_file","nullable":false,"type":"string"},{"metadata":{},"name":"taxi_type","nullable":false,"type":"string"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602277160,"submitTime":1773602269171,"finishTime":1773602289053,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",27]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"cd19e61c-be9f-4eed-ac1c-b6e89cadf0dc"},{"version":"CommandV1","origId":6943154431065657,"guid":"309c13e0-78a6-4917-aedb-6238e811945d","subtype":"command","commandType":"auto","position":9.0,"command":"df_pca_clustered.write.format(\"delta\").mode(\"overwrite\").saveAsTable(\"gold_quartiers_clustered\")\nprint(\"Table des quartiers clusterisés sauvegardée !\")","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Table des quartiers clusterisés sauvegardée !\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602557940,"submitTime":1773602557905,"finishTime":1773602563443,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",46]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"d01a9650-4cfa-4004-829f-6f5f06943949"},{"version":"CommandV1","origId":6943154431065656,"guid":"75c45062-d179-4dc2-9512-468f5c470517","subtype":"command","commandType":"auto","position":8.0,"command":"# Calcul de l'inertie pour K de 2 à 10\ninertias = []\nK_range = range(2, 11)\n\nfor k in K_range:\n    km = KMeans(k=k, seed=42, featuresCol=\"pca_features\")\n    model = km.fit(df_pca)\n    inertias.append(model.summary.trainingCost)\n\n# Graphique Elbow\nplt.figure(figsize=(10, 5))\nplt.plot(list(K_range), inertias, marker='o', color='steelblue', linewidth=2)\nplt.xlabel(\"Nombre de clusters (K)\")\nplt.ylabel(\"Inertie (Coût)\")\nplt.title(\"Méthode du coude (Elbow) - Détection du K optimal\")\nplt.xticks(list(K_range))\nplt.grid(True, alpha=0.3)\nplt.show()","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"mimeBundle","data":{"text/plain":"<Figure size 1000x500 with 1 Axes>","image/png":""},"executionCount":null,"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"kernelSessionId":"199fcd95-7f4bd4670b26e86810b41837"}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602494829,"submitTime":1773602494799,"finishTime":1773602544620,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["mimeBundle",null]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"2957f89b-5d54-4a5e-9701-84af8b2025b4"},{"version":"CommandV1","origId":6414892781516001,"guid":"b3bd9e02-3222-4269-9743-dff8bf00f313","subtype":"command","commandType":"auto","position":4.0,"command":"# Enrichir les Green avec les zones (Broadcast Join)\ndf_zones = (\n    spark.read.option(\"header\", \"true\").option(\"inferSchema\", \"true\")\n    .csv(\"/Workspace/Users/l.faloci@myskolae.fr/TP_Spark_folder/raw_data/taxi_zone_lookup.csv\")\n)\n\n# Agréger par quartier (PULocationID)\ndf_quartiers = (\n    df_all_taxis\n    .filter(col(\"PULocationID\").isNotNull())\n    .groupBy(\"PULocationID\")\n    .agg(\n        avg(\"trip_distance\").alias(\"avg_distance\"),\n        avg(\"total_amount\").alias(\"avg_fare\"),\n        avg(\"tip_amount\").alias(\"avg_tip\"),\n        count(\"*\").alias(\"trips_count\"),\n        sum(when(col(\"taxi_type\") == \"green\", 1).otherwise(0)).alias(\"green_count\"),\n        sum(when(col(\"taxi_type\") == \"yellow\", 1).otherwise(0)).alias(\"yellow_count\")\n    )\n    .withColumn(\"green_taxi_ratio\", col(\"green_count\") / col(\"trips_count\") * 100)\n)\n\n# Ajouter le nom du quartier\ndf_quartiers = df_quartiers.join(\n    broadcast(df_zones.select(\"LocationID\", \"Borough\", \"Zone\")),\n    df_quartiers[\"PULocationID\"] == col(\"LocationID\"),\n    \"left\"\n).drop(\"LocationID\")\n\ndisplay(df_quartiers.orderBy(\"trips_count\", ascending=False))\nprint(f\"Nombre de quartiers : {df_quartiers.count()}\")",