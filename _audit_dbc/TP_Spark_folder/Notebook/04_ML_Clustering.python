lable":false,"type":"long"},{"metadata":{},"name":"green_count","nullable":true,"type":"long"},{"metadata":{},"name":"yellow_count","nullable":true,"type":"long"},{"metadata":{},"name":"green_taxi_ratio","nullable":true,"type":"double"},{"metadata":{},"name":"Borough","nullable":true,"type":"string"},{"metadata":{},"name":"Zone","nullable":true,"type":"string"}],"type":"struct"},"tableIdentifier":null}],"metadata":{}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602302379,"submitTime":1773602269175,"finishTime":1773602308826,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["table",262],["ansi",26]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"1ccad996-30f1-4c7a-8bfd-be91f584bda3"},{"version":"CommandV1","origId":6943154431065654,"guid":"e5c26584-2674-4286-b6fc-fffae753edde","subtype":"command","commandType":"auto","position":6.0,"command":"from pyspark.ml.feature import PCA\n\n# ACP sur les données standardisées (réduction à 2 axes)\npca = PCA(k=2, inputCol=\"features_scaled\", outputCol=\"pca_features\")\npca_model = pca.fit(df_scaled)\n\ndf_pca = pca_model.transform(df_scaled)\n\n# Variance expliquée par chaque axe\nvariances = list(pca_model.explainedVariance)\nprint(\"Variance expliquée par axe :\")\nfor i, v in enumerate(variances):\n    print(f\"  Axe {i+1} : {round(v * 100, 2)}%\")\nprint(f\"  Total  : {round((variances[0] + variances[1]) * 100, 2)}%\")\n\n# K-Means sur les composantes ACP\nkmeans_pca = KMeans(k=4, seed=42, featuresCol=\"pca_features\", predictionCol=\"cluster_pca\")\nmodel_pca = kmeans_pca.fit(df_pca)\ndf_pca_clustered = model_pca.transform(df_pca)\n\nprint(\"\\nCentres des clusters (ACP) :\")\nfor i, center in enumerate(model_pca.clusterCenters()):\n    print(f\"  Cluster {i}: {[round(c, 2) for c in center]}\")","commandVersion":4,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Variance expliquée par axe :\n  Axe 1 : 32.73%\n  Axe 2 : 27.93%\n  Total  : 60.66%\n\nCentres des clusters (ACP) :\n  Cluster 0: [np.float64(-0.58), np.float64(0.13)]\n  Cluster 1: [np.float64(1.01), np.float64(1.67)]\n  Cluster 2: [np.float64(0.8), np.float64(-1.88)]\n  Cluster 3: [np.float64(5.16), np.float64(1.46)]\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_pca","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"PULocationID","nullable":true,"type":"long"},{"metadata":{},"name":"avg_distance","nullable":true,"type":"double"},{"metadata":{},"name":"avg_fare","nullable":true,"type":"double"},{"metadata":{},"name":"avg_tip","nullable":true,"type":"double"},{"metadata":{},"name":"trips_count","nullable":false,"type":"long"},{"metadata":{},"name":"green_count","nullable":true,"type":"long"},{"metadata":{},"name":"yellow_count","nullable":true,"type":"long"},{"metadata":{},"name":"green_taxi_ratio","nullable":true,"type":"double"},{"metadata":{},"name":"Borough","nullable":true,"type":"string"},{"metadata":{},"name":"Zone","nullable":true,"type":"string"},{"metadata":{"ml_attr":{