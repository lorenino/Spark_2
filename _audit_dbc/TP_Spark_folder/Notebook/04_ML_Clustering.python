eToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["ansi",25]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"956f1ce2-fd95-4e95-98f2-3988757f3625"},{"version":"CommandV1","origId":6943154431065655,"guid":"e55bff5a-bf37-4252-8193-fc6e9bd3ab2f","subtype":"command","commandType":"auto","position":7.0,"command":"import matplotlib.pyplot as plt\nimport numpy as np\nimport pandas as pd\n\n# --- Cercle de corrélation ---\nfeatures = [\"avg_distance\", \"avg_fare\", \"avg_tip\", \"trips_count\", \"green_taxi_ratio\"]\npc_matrix = pca_model.pc.toArray()  # matrice des composantes\n\nfig, axes = plt.subplots(1, 2, figsize=(18, 7))\n\n# Cercle de corrélation\nax1 = axes[0]\ncircle = plt.Circle((0, 0), 1, fill=False, color='gray', linestyle='--')\nax1.add_patch(circle)\nfor i, feat in enumerate(features):\n    ax1.arrow(0, 0, pc_matrix[i, 0], pc_matrix[i, 1], \n              head_width=0.05, head_length=0.03, fc='steelblue', ec='steelblue')\n    ax1.text(pc_matrix[i, 0] * 1.15, pc_matrix[i, 1] * 1.15, feat, fontsize=10, ha='center')\nax1.set_xlim(-1.2, 1.2)\nax1.set_ylim(-1.2, 1.2)\nax1.axhline(y=0, color='k', linewidth=0.5)\nax1.axvline(x=0, color='k', linewidth=0.5)\nax1.set_xlabel(\"Axe 1\")\nax1.set_ylabel(\"Axe 2\")\nax1.set_title(\"Cercle de corrélation ACP\")\nax1.set_aspect('equal')\n\n# --- Scatter des quartiers par cluster ACP ---\npdf = df_pca_clustered.select(\"Zone\", \"cluster_pca\", \"pca_features\").toPandas()\npdf[\"PC1\"] = pdf[\"pca_features\"].apply(lambda x: float(x[0]))\npdf[\"PC2\"] = pdf[\"pca_features\"].apply(lambda x: float(x[1]))\n\nax2 = axes[1]\nfor cluster_id in sorted(pdf[\"cluster_pca\"].unique()):\n    mask = pdf[\"cluster_pca\"] == cluster_id\n    ax2.scatter(pdf.loc[mask, \"PC1\"], pdf.loc[mask, \"PC2\"], label=f\"Cluster {cluster_id}\", s=50, alpha=0.7)\nax2.set_xlabel(\"Axe 1 (Volume/Business)\")\nax2.set_ylabel(\"Axe 2 (Banlieue/Green Taxi)\")\nax2.set_title(\"Segmentation des quartiers (ACP + K-Means)\")\nax2.legend()\n\nplt.tight_layout()\nplt.show()","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[{"type":"mimeBundle","data":{"text/plain":"<Figure size 1800x700 with 2 Axes>","image/png":""},"executionCount":null,"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{"kernelSessionId":"199fcd95-7f4bd4670b26e86810b41837"}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"pdf","typeStr":"pandas.core.frame.DataFrame","schema":{"type":"struct","fields":[{"name":"Zone","type":"object","nullable":true,"metadata":{}},{"name":"cluster_pca","type":"int32","nullable":true,"metadata":{}},{"name":"pca_features","type":"object","nullable":true,"metadata":{}},{"name":"PC1","type":"float64","nullable":true,"metadata":{}},{"name":"PC2","type":"float64","nullable":true,"metadata":{}}]},"tableIdentifier":null}],"metadata":{}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":null,"workflows":[],"startTime":1773602446232,"submitTime":1773602446183,"finishTime":1773602450000,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"latestAssumeRoleInfo":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"metadata":{"rowLimit":10000,"byteLimit":2048000},"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultIndex":null,"listResultMetadata":[["mimeBundle",null]],"subcommandOptions":null,"contentSha256Hex":null,"tableResultSettingsMap":{},"nuid":"57